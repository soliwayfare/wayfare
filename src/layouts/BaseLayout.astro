---
import { ClientRouter } from 'astro:transitions'
import { SITE } from '../consts'
import SiteHeader from '../components/SiteHeader.astro'
import SiteBackground from '../components/SiteBackground.astro'
import NavLoading from '../components/NavLoading.astro'
import Seo from '../components/Seo.astro'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  // Set 'article' on blog-post pages so Seo emits BlogPosting JSON-LD + og:type.
  type?: 'website' | 'article'
  publishedDate?: Date
}

const { title, description, type = 'website', publishedDate } = Astro.props
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title
const metaDesc = description || SITE.description
const year = new Date().getFullYear()
const copyrightYears =
  year === SITE.startYear ? `${year}` : `${SITE.startYear} - ${year}`
const canonical = new URL(Astro.url.pathname, Astro.site).href
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <Seo
      pageTitle={pageTitle}
      description={metaDesc}
      canonical={canonical}
      type={type}
      articleTitle={title}
      publishedDate={publishedDate}
    />
    <ClientRouter />
  </head>
  <body>
    <SiteBackground />
    <NavLoading />
    <div class="wrap" transition:name="page">
      <div
        class="page-surface"
        aria-hidden="true"
        transition:name="page-surface"
        transition:persist="page-surface"
      >
      </div>
      <SiteHeader />
      <main class="container">
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          © {copyrightYears}
          <a href="/">{SITE.author}</a>, powered by{' '}
          <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
        </p>
      </footer>
    </div>

    <script>
      import { DISQUS_SHORTNAME } from '../consts';

      // The header is re-rendered on each navigation, so build-time active
      // state is usually right — but recompute on every load as a safeguard.
      // NAV data-path values are full site paths; compare exactly.
      function syncActiveNav() {
        const path = location.pathname;
        document.querySelectorAll<HTMLAnchorElement>('.nav a[data-path]').forEach((a) => {
          a.classList.toggle('active', a.dataset.path === path);
        });
      }

      // Load (or reset) Disqus for the current post. With <ClientRouter /> the
      // page never fully reloads, so this runs on every navigation and reads
      // the per-post values from the #disqus_thread data attributes.
      function loadDisqus() {
        const el = document.getElementById('disqus_thread');
        if (!el) return;
        const w = window as any;
        w.disqus_config = function () {
          this.page.identifier = el.dataset.disqusIdentifier;
          this.page.url = el.dataset.disqusUrl;
          this.page.title = el.dataset.disqusTitle;
        };
        if (w.DISQUS) {
          w.DISQUS.reset({ reload: true, config: w.disqus_config });
        } else {
          const s = document.createElement('script');
          s.src = `https://${DISQUS_SHORTNAME}.disqus.com/embed.js`;
          s.setAttribute('data-timestamp', String(+new Date()));
          document.body.appendChild(s);
        }
      }

      document.addEventListener('astro:page-load', () => {
        syncActiveNav();
        loadDisqus();
      });
    </script>
  </body>
</html>

<style is:global>
  .wrap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: 52rem;
    margin: 0 auto;
  }

  .page-surface {
    position: absolute;
    inset: 0;
    z-index: 0;
    /* Semi-transparent solid (no backdrop-filter): a blurred sheet can't be
       captured by view transitions, which is what made it flash opaque / vanish
       mid-navigation. A plain translucent panel snapshots identically, so it
       transitions cleanly. */
    background: color-mix(in srgb, var(--paper) 92%, transparent);
    border-left: 1px solid var(--hairline);
    border-right: 1px solid var(--hairline);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12);
  }

  .container {
    width: 100%;
    max-width: var(--measure);
    margin: 0 auto;
    padding: 0 1.5rem;
    flex: 1 0 auto;
  }

  .site-footer {
    flex-shrink: 0;
    max-width: var(--measure);
    width: 100%;
    margin: var(--space-16) auto 0;
    padding: var(--space-6) 1.5rem var(--space-12);
    border-top: 1px solid var(--hairline);
    color: var(--ink-faint);
    font-size: 0.82rem;
    letter-spacing: 0.01em;
  }

  .site-footer a {
    color: var(--ink-soft);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease);
  }

  .site-footer a:hover {
    border-bottom-color: var(--accent);
  }

  .wrap > .container,
  .wrap > .site-footer {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 56rem) {
    .page-surface {
      border-left: none;
      border-right: none;
    }
  }

  @media (max-width: 640px) {
    body {
      font-size: 16px;
    }
  }
</style>
