---
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../consts';
import { withBase } from '../utils/url';
import Nav from '../components/Nav.astro';
import NavLoader from '../components/NavLoader.astro';
import SiteBackground from '../components/SiteBackground.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${SITE.title}` : SITE.title;
const metaDesc = description || SITE.description;
const year = new Date().getFullYear();
const copyrightYears = year === SITE.startYear ? `${year}` : `${SITE.startYear} - ${year}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/atom+xml" title={SITE.title} href={withBase('/atom.xml')} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body>
    <NavLoader />
    <SiteBackground />
    <div class="wrap">
      <div class="page-surface" transition:name="surface" aria-hidden="true"></div>
      <header class="site-header">
        <a class="logo-link" href={withBase('/')}>
          <h1>{SITE.title}</h1>
        </a>
        <Nav />
      </header>
      <main class="container">
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          © {copyrightYears}
          <a href="/">{SITE.author}</a>, powered by{' '}
          <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>.
        </p>
      </footer>
    </div>
    <GoogleAnalytics />

    <script>
      import { DISQUS_SHORTNAME } from '../consts';

      // The header is re-rendered on each navigation, so build-time active
      // state is usually right — but recompute on every load as a safeguard.
      // NAV data-path values are full site paths; compare exactly.
      function syncActiveNav() {
        const path = location.pathname;
        document.querySelectorAll<HTMLAnchorElement>('.nav a[data-path]').forEach((a) => {
          a.classList.toggle('active', a.dataset.path === path);
        });
      }

      // Load (or reset) Disqus for the current post. With <ClientRouter /> the
      // page never fully reloads, so this runs on every navigation and reads
      // the per-post values from the #disqus_thread data attributes.
      function loadDisqus() {
        const el = document.getElementById('disqus_thread');
        if (!el) return;
        const w = window as any;
        w.disqus_config = function () {
          this.page.identifier = el.dataset.disqusIdentifier;
          this.page.url = el.dataset.disqusUrl;
          this.page.title = el.dataset.disqusTitle;
        };
        if (w.DISQUS) {
          w.DISQUS.reset({ reload: true, config: w.disqus_config });
        } else {
          const s = document.createElement('script');
          s.src = `https://${DISQUS_SHORTNAME}.disqus.com/embed.js`;
          s.setAttribute('data-timestamp', String(+new Date()));
          document.body.appendChild(s);
        }
      }

      document.addEventListener('astro:page-load', () => {
        syncActiveNav();
        loadDisqus();
      });
    </script>
  </body>
</html>
