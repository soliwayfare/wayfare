---
import { ClientRouter } from 'astro:transitions';
import { SITE } from '../consts';
import Nav from '../components/Nav.astro';
import SiteBackground from '../components/SiteBackground.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? `${SITE.author} · Home`;
const metaDesc = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="author" content={SITE.author} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
  </head>
  <body class="home">
    <SiteBackground />
    <div class="home-wrap">
      <header class="home-header">
        <div class="masthead-glass" transition:name="surface" aria-hidden="true"></div>
        <a class="home-brand" href="/">{SITE.author}</a>
        <Nav />
      </header>
      <main class="home-main">
        <slot />
      </main>
    </div>

    <GoogleAnalytics />

    <script>
      // Decode the obfuscated email in the home card. The rotating background and
      // its controls now live in <SiteBackground /> (site-wide, persisted).
      function decodeEmail() {
        const mail = document.querySelector('#code');
        if (mail) mail.textContent = atob('aUBpd2oubW9l');
      }
      document.addEventListener('astro:page-load', decodeEmail);
    </script>

    <style is:global>
      /* Homepage-only layout, scoped to `body.home`. The rotating background
         (.bg), progress indicator and bg controls are site-wide now and live in
         global.css (rendered by <SiteBackground />). */

      body.home {
        min-height: 100vh;
        margin: 0;
      }

      /* Layout shell — lifted above the fixed background (z-index:0) */
      .home .home-wrap {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        padding: 1.25rem;
        gap: 1.25rem;
      }

      /* Top header: brand left, shared <Nav> right — same structure as the blog
         header. The readable glass bar lives in a separate .masthead-glass
         layer so it can carry its own view transition (it grows to fill the
         screen when leaving the homepage). The header itself is just layout. */
      .home .home-header {
        position: relative;
        flex-shrink: 0;
        width: 100%;
        max-width: 44rem;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-6);
        padding: 0.7rem 1.4rem;
      }

      /* The glass background of the home nav, behind the brand + nav. It shares
         transition:name="surface" with the blog's .page-surface, so on leaving
         the homepage this pill morphs (grows + thickens from frosted to nearly
         opaque) into the inner page's reading panel over the same photo. */
      .home .masthead-glass {
        position: absolute;
        inset: 0;
        z-index: 0;
        border-radius: 999px;
        background: color-mix(in srgb, var(--paper) 80%, transparent);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--hairline);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }

      /* Keep the brand + nav above the glass layer. */
      .home .home-header > .home-brand,
      .home .home-header > .nav {
        position: relative;
        z-index: 1;
      }

      .home .home-brand {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        color: var(--ink);
        white-space: nowrap;
      }

      .home .home-main {
        flex: 1 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .home .home-card {
        width: 38rem;
        max-width: 100%;
        padding: var(--space-12) var(--space-8);
        border-radius: 16px;
        background: color-mix(in srgb, var(--paper) 86%, transparent);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid var(--hairline);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 1px 2px rgba(0, 0, 0, 0.06);
      }

      @media (max-width: 640px) {
        .home .home-header {
          flex-direction: column;
          gap: var(--space-2);
        }
        .home .masthead-glass {
          border-radius: 18px;
        }
        .home .home-card {
          padding: var(--space-8) var(--space-6);
        }
      }
    </style>
  </body>
</html>
