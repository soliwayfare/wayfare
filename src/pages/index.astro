---
import HomeLayout from '../layouts/HomeLayout.astro';
import { getSortedPosts, postPath } from '../utils/posts';
import { withBase } from '../utils/url';
import { formatDate, isoDate } from '../utils/date';

const recent = (await getSortedPosts()).slice(0, 4);
---

<HomeLayout>
  <section class="home-card">
    <header class="profile">
      <img
        class="avatar"
        src="https://github.com/cnwangjie.png?size=176"
        width="88"
        height="88"
        alt="Wang Jie"
        loading="eager"
        referrerpolicy="no-referrer"
      />
      <h1 class="profile-name">Wang Jie</h1>
      <p class="profile-role">Technology&nbsp;·&nbsp;Games&nbsp;·&nbsp;Algorithms</p>
      <p class="profile-bio">
        A person who loves life and enjoys exploration and creation. This is my
        corner of the web — writing, projects, and the things I'm into.
      </p>

      <div class="socials">
        <a class="social" href="https://github.com/cnwangjie" target="_blank" rel="noopener" title="GitHub" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
          </svg>
        </a>
        <a class="social" href="https://x.com/wangjie000" target="_blank" rel="noopener" title="Twitter / X" aria-label="Twitter">
          <svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a class="social" href="https://steamcommunity.com/id/cnwangjie/" target="_blank" rel="noopener" title="Steam" aria-label="Steam">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M11.979 0C5.678 0 .511 4.86.022 11.037l6.432 2.658c.545-.371 1.203-.59 1.912-.59.063 0 .125.004.188.006l2.861-4.142V8.91c0-2.495 2.028-4.524 4.524-4.524 2.494 0 4.524 2.031 4.524 4.527s-2.03 4.525-4.524 4.525h-.105l-4.076 2.911c0 .052.004.105.004.159 0 1.875-1.515 3.396-3.39 3.396-1.635 0-3.016-1.173-3.331-2.727L.436 15.27C1.862 20.307 6.486 24 11.979 24c6.627 0 11.999-5.373 11.999-12S18.605 0 11.979 0zM7.54 18.21l-1.473-.61c.262.543.714.999 1.314 1.25 1.297.539 2.793-.076 3.332-1.375.263-.63.264-1.319.005-1.949s-.75-1.121-1.377-1.383c-.624-.26-1.29-.249-1.878-.03l1.523.63c.956.4 1.409 1.5 1.009 2.455-.397.957-1.497 1.41-2.454 1.012zm11.415-9.303c0-1.662-1.353-3.015-3.015-3.015-1.665 0-3.015 1.353-3.015 3.015 0 1.665 1.35 3.015 3.015 3.015 1.663 0 3.015-1.35 3.015-3.015zm-5.273-.005c0-1.252 1.013-2.266 2.265-2.266 1.249 0 2.266 1.014 2.266 2.266 0 1.251-1.017 2.265-2.266 2.265-1.253 0-2.265-1.014-2.265-2.265z" />
          </svg>
        </a>
        <a class="social" href="https://wiki.cnwangjie.com" target="_blank" rel="noopener" title="Wiki" aria-label="Wiki">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" /><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
          </svg>
        </a>
      </div>
    </header>

    {recent.length > 0 && (
      <section class="latest">
        <div class="latest-head">
          <h2>Latest writing</h2>
          <a class="latest-all" href={withBase('/')}>All posts →</a>
        </div>
        <ul class="latest-list">
          {recent.map((post) => (
            <li>
              <a class="latest-item" href={withBase(postPath(post))}>
                <time datetime={isoDate(post.data.date)}>{formatDate(post.data.date)}</time>
                <span class="latest-title" set:html={post.data.title} />
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="contact">
      <span>Email: <a class="contact-link" id="code">••••••</a></span>
      <span>PGP: <a class="contact-link" href="https://keybase.io/wangjie/pgp_keys.asc?fingerprint=f33bb5b5540b38289ba8a022e1f446333b36787a">0x3B36787A</a></span>
    </footer>
  </section>
</HomeLayout>

<style>
  /* ---------- Profile hero ---------- */
  .profile {
    text-align: center;
  }

  .avatar {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--hairline);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    background: var(--paper-raised);
  }

  .profile-name {
    margin: var(--space-4) 0 0;
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .profile-role {
    margin: var(--space-2) 0 0;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .profile-bio {
    margin: var(--space-4) auto 0;
    max-width: 30rem;
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* ---------- Social icons ---------- */
  .socials {
    display: flex;
    justify-content: center;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--hairline);
    background: var(--paper-raised);
    color: var(--ink-soft);
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease),
      background var(--dur) var(--ease), transform var(--dur) var(--ease);
  }

  .social:hover {
    color: var(--ink);
    border-color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-2px);
  }

  /* ---------- Latest writing ---------- */
  .latest {
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
  }

  .latest-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .latest-head h2 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .latest-all {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    transition: color var(--dur) var(--ease);
  }

  .latest-all:hover {
    color: var(--accent-strong);
  }

  .latest-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .latest-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--hairline);
  }

  .latest-list li:last-child .latest-item {
    border-bottom: none;
  }

  .latest-item time {
    flex-shrink: 0;
    width: 6.5rem;
    color: var(--ink-faint);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  .latest-title {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.4;
    transition: color var(--dur) var(--ease);
  }

  .latest-item:hover .latest-title {
    color: var(--accent);
  }

  /* ---------- Contact ---------- */
  .contact {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-6);
    margin-top: var(--space-8);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
    color: var(--ink-faint);
    font-size: 0.8rem;
  }

  .contact-link {
    color: var(--accent-strong);
    cursor: pointer;
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease);
  }

  .contact-link:hover {
    border-bottom-color: var(--accent);
  }

  @media (max-width: 640px) {
    .profile-name {
      font-size: 1.45rem;
    }
    .latest-item {
      flex-direction: column;
      gap: 0;
    }
    .latest-item time {
      width: auto;
    }
  }
</style>
