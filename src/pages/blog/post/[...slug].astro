---
import type { GetStaticPaths } from 'astro'
import { render } from 'astro:content'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import PostMeta from '../../../components/PostMeta.astro'
import Paginator from '../../../components/Paginator.astro'
import Disqus from '../../../components/Disqus.astro'
import {
  getSortedPosts,
  postPath,
  postSlug,
  plainExcerpt,
} from '../../../utils/posts'
import { withBase } from '../../../utils/url'
import { SITE } from '../../../consts'

export const getStaticPaths = (async () => {
  const posts = await getSortedPosts()
  return posts.map((post, i) => ({
    params: { slug: postSlug(post) },
    props: {
      post,
      // "上一篇" -> newer post, "下一篇" -> older post.
      newer: posts[i - 1] ?? null,
      older: posts[i + 1] ?? null,
    },
  }))
}) satisfies GetStaticPaths

const { post, newer, older } = Astro.props
const { Content } = await render(post)

// Keep the old Hexo page.path so existing Disqus threads stay attached.
const identifier = `post/${postSlug(post)}/`
const url = new URL(Astro.url.pathname, Astro.site).href
const description = plainExcerpt(post) || SITE.description
---

<BaseLayout
  title={post.data.title}
  description={description}
  type="article"
  publishedDate={post.data.date}
>
  <article class="post-single">
    <h1 class="post-title" set:html={post.data.title} />
    <PostMeta date={post.data.date} from={post.data.from} />
    <div class="post-content">
      <Content />
    </div>
    {
      post.data.tags.length > 0 && (
        <div class="post-tags">
          <span class="label">标签</span>
          {post.data.tags.map((tag) => (
            <a class="tag-chip" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>
              {tag}
            </a>
          ))}
        </div>
      )
    }
  </article>

  <Paginator
    prevLabel="上一篇"
    nextLabel="下一篇"
    prevUrl={newer ? withBase(postPath(newer)) : null}
    nextUrl={older ? withBase(postPath(older)) : null}
  />

  {post.data.comments && <Disqus identifier={identifier} url={url} title={post.data.title} />}
</BaseLayout>

<style is:global>
  .post-single {
    padding-top: var(--space-2);
  }

  .post-single .post-title {
    font-size: clamp(1.9rem, 5vw, 2.4rem);
    line-height: 1.18;
    margin-bottom: var(--space-3);
  }

  .post-content {
    margin-top: var(--space-8);
    font-size: 1.0625rem;
  }

  .post-content > *:first-child {
    margin-top: 0;
  }

  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4 {
    line-height: 1.3;
    margin: var(--space-12) 0 var(--space-4);
    font-weight: 700;
    letter-spacing: -0.015em;
    scroll-margin-top: 1.5rem;
  }

  .post-content h2 {
    font-size: 1.45rem;
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--hairline);
  }

  .post-content h3 {
    font-size: 1.2rem;
  }

  .post-content h4 {
    font-size: 1.05rem;
  }

  .post-content p,
  .post-content ul,
  .post-content ol {
    margin: var(--space-4) 0;
  }

  .post-content ul,
  .post-content ol {
    padding-left: 1.4em;
  }

  .post-content li {
    margin: var(--space-2) 0;
  }

  .post-content li::marker {
    color: var(--accent);
  }

  .post-content img {
    display: block;
    margin: var(--space-8) auto;
    border-radius: var(--radius);
    border: 1px solid var(--hairline);
  }

  .post-content blockquote {
    margin: var(--space-8) 0;
    padding: var(--space-2) 0 var(--space-2) var(--space-6);
    border-left: 3px solid var(--accent);
    color: var(--ink-soft);
    font-style: italic;
  }

  .post-content blockquote p {
    margin: var(--space-2) 0;
  }

  .post-content blockquote p:first-child {
    margin-top: 0;
  }

  .post-content blockquote p:last-child {
    margin-bottom: 0;
  }

  .post-content :not(pre) > code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    color: var(--code-inline);
    background: var(--code-inline-bg);
    padding: 0.15em 0.42em;
    border-radius: 4px;
    word-break: break-word;
  }

  .post-content .expressive-code {
    margin: var(--space-6) 0;
  }

  .post-content hr {
    border: 0;
    margin: var(--space-12) auto;
    width: 100%;
    text-align: center;
  }

  .post-content hr::before {
    content: "· · ·";
    color: var(--ink-faint);
    letter-spacing: 0.6em;
    font-size: 1rem;
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
    font-size: 0.94rem;
    display: block;
    overflow-x: auto;
  }

  .post-content th,
  .post-content td {
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--hairline);
    text-align: left;
    vertical-align: top;
  }

  .post-content thead th {
    background: var(--paper-raised);
    font-weight: 600;
  }

  .post-content tbody tr:nth-child(2n) {
    background: var(--paper-raised);
  }

  .post-content iframe,
  .post-content video {
    max-width: 100%;
    margin: var(--space-6) auto;
    display: block;
    border-radius: var(--radius);
  }

  .post-content a {
    color: var(--accent-strong);
    background-image: linear-gradient(var(--accent), var(--accent));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 100% 1px;
    transition:
      background-size var(--dur) var(--ease),
      color var(--dur) var(--ease);
    padding-bottom: 1px;
  }

  .post-content a:hover {
    color: var(--accent);
    background-size: 100% 2px;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline);
  }

  .post-tags .label {
    color: var(--ink-faint);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }

  .comments {
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    border-top: 1px solid var(--hairline);
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    padding: 0.3rem 0.85rem;
    background: var(--paper-raised);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    font-size: 0.85rem;
    color: var(--ink-soft);
    transition:
      color var(--dur) var(--ease),
      border-color var(--dur) var(--ease),
      background var(--dur) var(--ease);
  }

  .tag-chip:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .post-content {
      font-size: 1rem;
    }
  }
</style>
