---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import MastodonFeed from '../../../components/MastodonFeed'
import { MASTODON } from '../../../consts'

const profileUrl = `https://${MASTODON.instance}/@${MASTODON.handle}`
---

<BaseLayout title="Mastodon" description="嘟文 · 来自 Mastodon 的近期动态">
  <h1 class="page-title">Mastodon</h1>
  <p class="masto-intro">
    来自 <a href={profileUrl} target="_blank" rel="me noopener">@{MASTODON.handle}@{MASTODON.instance}</a> 的近期嘟文，实时获取。
  </p>

  <MastodonFeed instance={MASTODON.instance} handle={MASTODON.handle} client:load />
</BaseLayout>

<style>
  .page-title {
    font-size: 1.7rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: var(--space-4) 0 var(--space-8);
  }

  .masto-intro {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0 0 var(--space-8);
  }

  .masto-intro a {
    color: var(--accent-strong);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease);
  }

  .masto-intro a:hover {
    border-bottom-color: var(--accent);
  }
</style>
