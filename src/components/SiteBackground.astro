---
// Site-wide rotating photo background, shared across every page. The elements
// are persisted across navigations (transition:persist) so the SAME image stays
// in place as you move between pages — that continuity is what lets the home
// nav glass expand over a stable backdrop. The rotation loop is started once per
// session: <ClientRouter /> keeps the same window, so the timers in the script's
// closure survive navigation and must not be re-initialised or torn down.
//
// The rotation progress shows as a ring on the pause FAB (bottom-right) instead
// of a top bar; the ring fills from real elapsed time so it lands exactly when
// the image changes.
---

<div class="bg" transition:name="site-bg" transition:persist="site-bg"></div>

<div class="bg-controls" transition:name="site-bg-controls" transition:persist="site-bg-controls">
  <button class="bg-fab" id="bg-pause" title="Pause" aria-label="Pause background rotation">
    <svg class="bg-fab-ring" viewBox="0 0 48 48" aria-hidden="true">
      <circle class="bg-fab-track" cx="24" cy="24" r="21" fill="none" />
      <circle class="bg-fab-progress" cx="24" cy="24" r="21" fill="none" />
    </svg>
    <span class="bg-fab-icon">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <rect x="6" y="5" width="4" height="14" rx="1" /><rect x="14" y="5" width="4" height="14" rx="1" />
      </svg>
    </span>
  </button>
  <button class="bg-btn" id="bg-save" title="Save image" aria-label="Save background image">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" />
    </svg>
  </button>
</div>

<script>
  import { dynamicBackground, type BgControls } from '../scripts/dynamic-background';

  const PAUSE_ICON =
    '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="6" y="5" width="4" height="14" rx="1"/><rect x="14" y="5" width="4" height="14" rx="1"/></svg>';
  const PLAY_ICON =
    '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M7 5.5v13a1 1 0 0 0 1.52.85l10.5-6.5a1 1 0 0 0 0-1.7L8.52 4.65A1 1 0 0 0 7 5.5z"/></svg>';

  const w = window as any;

  // Start the rotation exactly once for the whole session. The elements above
  // are persisted, so on later navigations they (and this running loop) are
  // already in place — re-initialising would spawn duplicate timers.
  if (!w.__bgStarted) {
    w.__bgStarted = true;
    const controls: BgControls | undefined = dynamicBackground();
    w.__bgControls = controls;

    const pauseBtn = document.querySelector<HTMLButtonElement>('#bg-pause');
    const icon = pauseBtn?.querySelector<HTMLElement>('.bg-fab-icon');
    const saveBtn = document.querySelector<HTMLButtonElement>('#bg-save');
    let paused = false;

    pauseBtn?.addEventListener('click', () => {
      if (!controls || !icon) return;
      paused = !paused;
      if (paused) {
        controls.pause();
        icon.innerHTML = PLAY_ICON;
        pauseBtn.title = 'Resume';
      } else {
        controls.resume();
        icon.innerHTML = PAUSE_ICON;
        pauseBtn.title = 'Pause';
      }
    });

    saveBtn?.addEventListener('click', () => controls?.saveCurrentImage());
  }
</script>

<style is:global>
  .bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    opacity: 1;
    background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
    background-size: 400% 400%;
    animation: bg-gradient 15s ease infinite;
    transition: opacity 4s ease-in-out;
  }

  .bg .cur {
    position: absolute;
    inset: 0;
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
  }

  .bg .cur.bg-enter {
    animation: bg-fadein 1s;
  }

  @keyframes bg-fadein {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  @keyframes bg-gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  .bg-controls {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: var(--space-3);
    z-index: 10;
  }

  .bg-fab {
    position: relative;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border: none;
    border-radius: 50%;
    padding: 0;
    background: color-mix(in srgb, var(--paper) 72%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.14);
    color: var(--ink-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .bg-fab:hover {
    color: var(--ink);
    transform: translateY(-1px);
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.18);
  }

  .bg-fab:active {
    transform: translateY(0);
  }

  .bg-fab-ring {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
    pointer-events: none;
  }

  .bg-fab-track {
    stroke: color-mix(in srgb, var(--ink) 14%, transparent);
    stroke-width: 2.5;
  }

  .bg-fab-progress {
    stroke: var(--accent);
    stroke-width: 2.5;
    stroke-linecap: round;
  }

  .bg-fab-icon {
    display: flex;
    position: relative;
  }

  .bg-btn {
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: color-mix(in srgb, var(--paper) 72%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    color: var(--ink-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px) scale(0.8);
    pointer-events: none;
    transition:
      opacity var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease);
  }

  .bg-controls:hover .bg-btn,
  .bg-controls:focus-within .bg-btn {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .bg-btn:hover {
    color: var(--ink);
    transform: translateY(-1px) scale(1);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.16);
  }

  .bg-btn:active {
    transform: translateY(0) scale(1);
  }
</style>
