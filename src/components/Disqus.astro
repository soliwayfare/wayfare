---
interface Props {
  // Stable thread id; must match the old Hexo page.path to keep existing
  // comment threads (e.g. "post/why-not-try-linux/").
  identifier: string;
  // Canonical page URL used by Disqus, matching the old config.url + path.
  url: string;
  title: string;
}

const { identifier, url, title } = Astro.props;
---

{/* Loading is handled by a global astro:page-load handler in BaseLayout that
    reads these data attributes — required because <ClientRouter /> navigates
    without a full reload, so inline scripts here would not re-run per post. */}
<section class="comments">
  <div
    id="disqus_thread"
    data-disqus-identifier={identifier}
    data-disqus-url={url}
    data-disqus-title={title}
  >
  </div>
  <noscript
    >Please enable JavaScript to view the
    <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript
  >
</section>
