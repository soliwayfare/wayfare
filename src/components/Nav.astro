---
import { NAV } from '../consts';

// NAV hrefs are already full site paths, so the active item is an exact match
// against the current pathname (home `/` only matches `/`, not `/blog/...`).
const current = Astro.url.pathname;
---

<ul class="nav">
  {
    NAV.map((item) => {
      const active = !item.external && current === item.href;
      return (
        <li>
          <a
            href={item.href}
            class={active ? 'active' : undefined}
            data-path={item.external ? undefined : item.href}
            target={item.external ? '_blank' : undefined}
            rel={item.external ? 'noopener' : undefined}
          >
            {item.label}
          </a>
        </li>
      );
    })
  }
</ul>
