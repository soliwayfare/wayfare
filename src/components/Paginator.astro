---
interface Props {
  // Resolved hrefs (already base-prefixed) or null when absent.
  prevLabel: string
  nextLabel: string
  prevUrl?: string | null
  nextUrl?: string | null
}

const { prevLabel, nextLabel, prevUrl, nextUrl } = Astro.props
---

{
  (prevUrl || nextUrl) && (
    <nav class="paginator">
      {prevUrl ? (
        <a class="prev" href={prevUrl}>
          {prevLabel}
        </a>
      ) : (
        <span />
      )}
      {nextUrl && (
        <a class="next" href={nextUrl}>
          {nextLabel}
        </a>
      )}
    </nav>
  )
}

<style is:global>
  .paginator {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-12);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .paginator a {
    color: var(--ink-soft);
    transition: color var(--dur) var(--ease);
  }

  .paginator a:hover {
    color: var(--accent);
  }

  .paginator .next {
    margin-left: auto;
    text-align: right;
  }
</style>
