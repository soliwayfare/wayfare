# Cloudflare static-asset response headers. Copied verbatim from public/ to
# dist/ at build time and applied by the Worker's asset server.
# Rules are matched top-to-bottom; more specific paths below override the
# Cache-Control set on /*.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' https: data: blob:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://*.disqus.com https://*.disquscdn.com; connect-src 'self' https://c.im https://*.disqus.com; frame-src https://*.disqus.com; upgrade-insecure-requests
  Cache-Control: public, max-age=0, must-revalidate

# Hashed, content-addressed bundles never change — cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts are versioned by deploy; safe to cache long.
/blog/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Post images change rarely; cache a month, allow background revalidation.
/blog/images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

/favicon.svg
  Cache-Control: public, max-age=604800
/favicon.ico
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
